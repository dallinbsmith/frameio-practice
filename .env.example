# =============================================================================
# Frame.io Marketing Study Guide
# Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# =============================================================================
# Application
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Frame.io Study Guide"

# =============================================================================
# Feature Flags
# =============================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=true

# =============================================================================
# API Keys (Add as needed in future steps)
# =============================================================================
# SANITY_PROJECT_ID=
# SANITY_DATASET=
# SANITY_API_TOKEN=

# NEXT_PUBLIC_SEGMENT_WRITE_KEY=
# NEXT_PUBLIC_GTM_ID=

# =============================================================================
# External Services (Add as needed in future steps)
# =============================================================================
# CALENDLY_API_KEY=
# WISTIA_API_PASSWORD=
